# ==========================
# Application
# ==========================

APP_NAME=Delivery Command Center

APP_VERSION=1.0.0

LOG_LEVEL=INFO

MAX_RISKS_IN_REPORT=5

ENABLE_MCP=true

# ==========================
# Provider Selection
# ==========================

LLM_PROVIDER=gemini

# ==========================
# Gemini
# ==========================

GEMINI_API_KEY=

GEMINI_MODEL=gemini-2.5-flash

# ==========================
# OpenAI
# ==========================

OPENAI_API_KEY=

OPENAI_MODEL=gpt-5

# ==========================
# Anthropic (Future)
# ==========================

ANTHROPIC_API_KEY=

ANTHROPIC_MODEL=claude-sonnet-4

# ==========================
# AWS Bedrock (Future)
# ==========================

AWS_REGION=us-east-1

AWS_ACCESS_KEY_ID=

AWS_SECRET_ACCESS_KEY=

BEDROCK_MODEL=anthropic.claude-3-sonnet

# ==========================
# Data Sources
# ==========================

PROJECT_DATA_FILE=examples/sample_project.json

RISK_DATA_FILE=examples/sample_risks.json

STAKEHOLDER_DATA_FILE=examples/sample_stakeholders.json
